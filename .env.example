# ─── Sync job ──────────────────────────────────────────────────────
SYNC_RUN_ID=                                       # Optional explicit run ID (default: ISO timestamp)
SYNC_PIPELINES=courses,learners,recommendations    # Comma-separated; empty = all registered
SYNC_DRY_RUN=false                                 # If true, read from BQ but skip Cosmos writes
SYNC_MAX_PARALLEL_PIPELINES=1                      # Run N pipelines concurrently
SYNC_FAIL_FAST=false                               # Stop after first pipeline failure
LOG_LEVEL=INFO

# ─── BigQuery ──────────────────────────────────────────────────────
BQ_PROJECT_ID=                                     # e.g. learnsphere-prod
BQ_DATASET=learnsphere                             # Source dataset
BQ_LOCATION=US                                     # Dataset location
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json  # Path to mounted SA JSON

# ─── Cosmos DB ─────────────────────────────────────────────────────
# Production auth is always Microsoft Entra ID via managed identity (in Azure)
# or `az login` (locally against a real account). The IaC disables shared-key
# auth on the Cosmos account. COSMOS_EMULATOR_KEY is only honoured when the
# endpoint host is localhost / cosmos-emulator (for docker-compose dev).
COSMOS_ENDPOINT=                                   # https://<acct>.documents.azure.com:443/
COSMOS_DATABASE=learnsphere
COSMOS_VERIFY_TLS=true                             # Set false only for the local emulator
COSMOS_UPSERT_CONCURRENCY=16                       # In-flight upserts per pipeline
COSMOS_BATCH_SIZE=500                              # Rows per checkpoint flush
COSMOS_EMULATOR_KEY=                               # Emulator-only escape hatch; leave unset for any real Cosmos account

# ─── Identity (Azure) ──────────────────────────────────────────────
AZURE_CLIENT_ID=                                   # User-assigned managed identity client ID (prod)

# ─── Observability ─────────────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=             # Set in prod; empty disables Azure Monitor exporter
OTEL_SERVICE_NAME=bq-cosmos-sync
